# Mickey Jagger Environment Variables

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
BACKEND_LOG_LEVEL=info

# Avatar Engine Configuration
ENGINE_TYPE=landmark_warp
ENGINE_DEVICE=cpu
ENGINE_TARGET_FPS=30
ENGINE_OUTPUT_SIZE=512
ENGINE_SMOOTHING_FACTOR=0.7
ENGINE_MOTION_SCALE=1.0

# CORS Configuration
CORS_ORIGINS=*

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760
TEMP_DIR=/tmp/mickey_jagger

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30
WS_MAX_FRAME_QUEUE=5

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# OBS Mode Configuration
OBS_BACKGROUND_COLOR=transparent
OBS_GREEN_SCREEN_KEY=none
