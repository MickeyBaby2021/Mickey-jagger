# Mickey Jagger Backend Configuration

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=info

# Avatar Engine
ENGINE_TYPE=landmark_warp
DEVICE=cpu  # cpu, cuda, mps
TARGET_FPS=30
OUTPUT_SIZE=512
SMOOTHING_FACTOR=0.7
MOTION_SCALE=1.0

# CORS (comma-separated origins)
CORS_ORIGINS=*

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB
TEMP_DIR=/tmp/mickey_jagger

# WebSocket
WS_HEARTBEAT_INTERVAL=30
WS_MAX_FRAME_QUEUE=5
